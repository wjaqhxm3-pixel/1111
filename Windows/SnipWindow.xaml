<Window x:Class="ScreenSealWindows.Windows.SnipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross">
    <Grid>
        <Canvas x:Name="SnipCanvas">
            <!-- Semi-transparent overlay covering the entire screen -->
            <Canvas.Background>
                <SolidColorBrush Color="Black" Opacity="0.3" />
            </Canvas.Background>

            <!-- Selection rectangle -->
            <Border x:Name="SelectionRect"
                    BorderBrush="#00AAFF"
                    BorderThickness="2"
                    Background="#2000AAFF"
                    Visibility="Collapsed" />

            <!-- Instruction text -->
            <TextBlock x:Name="InstructionText"
                       Text="드래그하여 모자이크 영역을 선택하세요 (ESC: 취소)"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"
                       Canvas.Left="20"
                       Canvas.Top="20">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" Color="Black" BlurRadius="3" />
                </TextBlock.Effect>
            </TextBlock>
        </Canvas>
    </Grid>
</Window>
