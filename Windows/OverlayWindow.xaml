<Window x:Class="ScreenSealWindows.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Opacity="0.99"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        MinWidth="10" MinHeight="10"
        Width="300" Height="200"
        Left="200" Top="200">
    <Grid x:Name="MainGrid">
        <!-- The mosaic image is rendered here -->
        <Image x:Name="MosaicImage"
               Stretch="Fill"
               RenderOptions.BitmapScalingMode="NearestNeighbor" />

        <!-- Close button: top-right, visible on mouse hover -->
        <Button x:Name="CloseButton"
                Content="✕"
                Width="24" Height="24"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,2,2,0"
                Opacity="0"
                Cursor="Hand"
                Click="CloseButton_Click"
                FontSize="12" FontWeight="Bold"
                Foreground="White"
                IsHitTestVisible="True">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BtnBorder"
                            Background="#CC333333"
                            CornerRadius="12"
                            BorderBrush="#80FFFFFF"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background" Value="#CCCC3333" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Resize grip visual indicator -->
        <Border x:Name="ResizeBorder"
                BorderBrush="#40FFFFFF"
                BorderThickness="2"
                Opacity="0"
                IsHitTestVisible="False" />

        <ResizeGrip x:Name="CustomResizeGrip"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Opacity="0"
                    IsHitTestVisible="True"
                    Cursor="SizeNWSE"
                    MouseLeftButtonDown="CustomResizeGrip_MouseLeftButtonDown" />
    </Grid>
</Window>
