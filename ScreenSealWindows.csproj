<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>ScreenSealWindows</AssemblyName>
    <RootNamespace>ScreenSealWindows</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="ScreenSealWindows.Tests\**" />
    <Content Remove="ScreenSealWindows.Tests\**" />
    <EmbeddedResource Remove="ScreenSealWindows.Tests\**" />
    <None Remove="ScreenSealWindows.Tests\**" />
  </ItemGroup>
</Project>
